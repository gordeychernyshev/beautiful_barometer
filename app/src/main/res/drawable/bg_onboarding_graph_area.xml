<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="?attr/colorSurface" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorOutlineVariant" />
        </shape>
    </item>
    <item android:top="18dp" android:bottom="18dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="0"
                android:endColor="?attr/colorPrimaryContainer"
                android:startColor="?attr/colorSurfaceContainerHighest" />
            <stroke
                android:width="2dp"
                android:color="?attr/colorPrimary" />
        </shape>
    </item>
</layer-list>
