<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.08"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <com.example.beautiful_barometer.ui.PressureGaugeView
                android:id="@+id/gauge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp" />

            <TextView
                android:id="@+id/textPressure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.Material3.DisplaySmall" />

            <LinearLayout
                android:id="@+id/altitudesRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textAltitudeCurrent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="64dp"
                    android:text="0 м"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

                <TextView
                    android:id="@+id/textAltitudeDelta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0 м"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />
            </LinearLayout>

            <TextView
                android:id="@+id/textAltitudeBase"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:text="@string/base_altitude_default"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGraph"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="@string/btn_graph" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/btn_settings" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.92"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <LinearLayout
                android:id="@+id/trendRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTrend3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:id="@+id/ivTrend3Arrow"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/trend_3h"
                            android:src="@drawable/ic_trend_arrow"
                            app:tint="?attr/colorOutlineVariant" />

                        <TextView
                            android:id="@+id/tvTrend3Delta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="—"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvTrend3Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/trend_3h"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTrend24"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <ImageView
                            android:id="@+id/ivTrend24Arrow"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/trend_24h"
                            android:src="@drawable/ic_trend_arrow"
                            app:tint="?attr/colorOutlineVariant" />

                        <TextView
                            android:id="@+id/tvTrend24Delta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="—"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvTrend24Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/trend_24h"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardForecast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvForecastIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⛅"
                        android:textSize="18sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvForecastTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="@string/forecast_title_default"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        app:layout_constraintStart_toEndOf="@id/tvForecastIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvForecastSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/forecast_not_enough_data"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        app:layout_constraintTop_toBottomOf="@id/tvForecastTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvForecastDesc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/forecast_summary_unknown"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        app:layout_constraintTop_toBottomOf="@id/tvForecastSubtitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.example.beautiful_barometer.ui.forecast.ForecastSparklineView
                        android:id="@+id/forecastSparkline"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tvForecastDesc"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/forecastChipsRow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleLine="false"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp"
                        app:layout_constraintTop_toBottomOf="@id/forecastSparkline"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDelta1h"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forecast_delta_1h_unknown"
                            app:chipBackgroundColor="@android:color/transparent"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDelta3h"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forecast_delta_3h_unknown"
                            app:chipBackgroundColor="@android:color/transparent"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipQuality"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forecast_quality_unknown"
                            app:chipBackgroundColor="@android:color/transparent"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipNoise"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forecast_noise_unknown"
                            app:chipBackgroundColor="@android:color/transparent"
                            app:chipStrokeColor="?attr/colorOutlineVariant"
                            app:chipStrokeWidth="1dp" />
                    </com.google.android.material.chip.ChipGroup>

                    <LinearLayout
                        android:id="@+id/forecastConfidenceRow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/forecastChipsRow"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/tvForecastConfidenceTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forecast_confidence_unknown"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressForecastConfidence"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:max="100"
                            android:progress="0"
                            app:trackStopIndicatorSize="0dp" />

                        <TextView
                            android:id="@+id/tvForecastConfidenceHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/forecast_confidence_hint_unknown"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvForecastReasons"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        app:layout_constraintTop_toBottomOf="@id/forecastConfidenceRow"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvForecastCompare"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text=""
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        app:layout_constraintTop_toBottomOf="@id/tvForecastReasons"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvForecastAdvice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text=""
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/tvForecastCompare"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
